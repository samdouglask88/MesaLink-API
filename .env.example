# Modelo de variáveis de ambiente para desenvolvimento local.
# Copie para `.env` e preencha com os valores impressos por `supabase start`.
# O `.env` real NÃO é versionado (ver .gitignore).

# URL da API/Functions local
SUPABASE_URL="http://127.0.0.1:54321"

# Chaves impressas por `supabase start`
SUPABASE_ANON_KEY="cole-aqui-a-anon-key"
SUPABASE_SERVICE_ROLE_KEY="cole-aqui-a-service-role-key"

# Base das Edge Functions (default: ${SUPABASE_URL}/functions/v1)
FUNCTIONS_URL="http://127.0.0.1:54321/functions/v1"

# Liga os testes de integração (ver README). Deixe 0/ausente para rodar só os unitários.
INTEGRATION="0"
